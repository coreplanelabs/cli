# Maintainer: Coreplane Labs <support@coreplane.dev>
# Arch Linux PKGBUILD for the `nominal` AUR package.
#
# Published to aur.archlinux.org under pkgname=nominal. The release pipeline
# bumps `pkgver` + `sha256sums` and pushes to the AUR repo on each new release
# (see the update-aur job in .github/workflows/release.yml).

pkgname=nominal
_npmname=@coreplane/nominal
_tarname=nominal                 # tarball filename after /-/ uses the unscoped basename
pkgver=0.1.0
pkgrel=1
pkgdesc='Agent-focused CLI for the Nominal platform'
arch=('any')
url='https://nominal.dev'
license=('MIT')
depends=('nodejs>=18')
makedepends=('npm')
source=("https://registry.npmjs.org/${_npmname}/-/${_tarname}-${pkgver}.tgz")
sha256sums=('SKIP') # replaced by CI with the real sum on release
noextract=("${_tarname}-${pkgver}.tgz")

package() {
  npm install \
    --global \
    --prefix "${pkgdir}/usr" \
    --no-audit \
    --no-fund \
    --omit=dev \
    "${srcdir}/${_tarname}-${pkgver}.tgz"

  # npm sometimes leaves references to srcdir in symlinks — resolve them
  find "${pkgdir}/usr" -type l -exec sh -c '
    for l in "$@"; do
      t="$(readlink "$l")"
      case "$t" in /*) ln -sf "${t#${PKGDIR}}" "$l" ;; esac
    done
  ' sh {} + 2>/dev/null || true

  install -Dm644 "${pkgdir}/usr/lib/node_modules/${_npmname}/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
}
